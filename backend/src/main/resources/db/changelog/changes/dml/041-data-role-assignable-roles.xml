<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
						http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

	<!--
		role_template_assignable_roles seed data.
		Defines which template roles each template role is allowed to assign.

		Template IDs (from 039-data-role-templates.xml):
			1 = ADMIN, 2 = MEMBER

		Policy:
			ADMIN  → can assign MEMBER
			MEMBER → (none)

		SUPER_ADMIN bypasses governance entirely (handled in code).
		Tenant-level role_assignable_roles entries are created during provisioning
		by RoleTemplateService, mapping these template relationships to tenant-scoped roles.
	-->

	<!-- ADMIN can assign MEMBER -->
	<changeSet id="d1e2f3a4-0041-4aaa-b001-tplassrole-01" author="mosque-crm">
		<customChange class="com.mosque.crm.liquibase.DataRoleTemplateAssignableRole">
			<param name="templateId"><![CDATA[1]]></param><param name="assignableTemplateId"><![CDATA[2]]></param>
		</customChange>
	</changeSet>

</databaseChangeLog>
