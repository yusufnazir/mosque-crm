<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <!-- ═══════════ FEDERATION / PARTNERSHIPS ═══════════ -->
    <changeSet id="a1b2c3d4-0079-4fed-aaaa-partnershipview079" author="mosque-crm">
        <customChange class="com.mosque.crm.liquibase.DataPermission">
            <param name="id"><![CDATA[79]]></param>
            <param name="code"><![CDATA[partnership.view]]></param>
            <param name="description"><![CDATA[View organization partnerships and federation sharing settings]]></param>
            <param name="category"><![CDATA[partnership]]></param>
        </customChange>
    </changeSet>
    <changeSet id="b2c3d4e5-0080-4fed-bbbb-partnershipmgmt080" author="mosque-crm">
        <customChange class="com.mosque.crm.liquibase.DataPermission">
            <param name="id"><![CDATA[80]]></param>
            <param name="code"><![CDATA[partnership.manage]]></param>
            <param name="description"><![CDATA[Invite, request, approve, and manage organization partnerships]]></param>
            <param name="category"><![CDATA[partnership]]></param>
        </customChange>
    </changeSet>

    <!-- ═══════════ BUSINESS DIRECTORY ═══════════ -->
    <changeSet id="c3d4e5f6-0081-4fed-cccc-businessdirview081" author="mosque-crm">
        <customChange class="com.mosque.crm.liquibase.DataPermission">
            <param name="id"><![CDATA[81]]></param>
            <param name="code"><![CDATA[business_directory.view]]></param>
            <param name="description"><![CDATA[View local and federation business directory listings]]></param>
            <param name="category"><![CDATA[business_directory]]></param>
        </customChange>
    </changeSet>
    <changeSet id="d4e5f6a7-0082-4fed-dddd-businessdirmgmt082" author="mosque-crm">
        <customChange class="com.mosque.crm.liquibase.DataPermission">
            <param name="id"><![CDATA[82]]></param>
            <param name="code"><![CDATA[business_directory.manage]]></param>
            <param name="description"><![CDATA[Register and manage business directory listings]]></param>
            <param name="category"><![CDATA[business_directory]]></param>
        </customChange>
    </changeSet>

    <changeSet id="e5f6a7b8-0083-4fed-eeee-backfill-federation-perms" author="mosque-crm">
        <comment>Backfill federation permissions to ADMIN templates and existing ADMIN roles</comment>
        <sql>
            INSERT IGNORE INTO role_template_permissions (template_id, permission_id) VALUES (1, 79), (1, 80), (1, 81), (1, 82);
            INSERT IGNORE INTO role_template_assignable_permissions (template_id, permission_id) VALUES (1, 79), (1, 80), (1, 81), (1, 82);

            INSERT IGNORE INTO role_permissions (role_id, permission_id)
            SELECT r.id, p.id
            FROM roles r
            JOIN permissions p ON p.code IN ('partnership.view', 'partnership.manage', 'business_directory.view', 'business_directory.manage')
            WHERE r.name = 'ADMIN';

            INSERT IGNORE INTO role_assignable_permissions (role_id, permission_id)
            SELECT r.id, p.id
            FROM roles r
            JOIN permissions p ON p.code IN ('partnership.view', 'partnership.manage', 'business_directory.view', 'business_directory.manage')
            WHERE r.name = 'ADMIN';
        </sql>
    </changeSet>

</databaseChangeLog>
