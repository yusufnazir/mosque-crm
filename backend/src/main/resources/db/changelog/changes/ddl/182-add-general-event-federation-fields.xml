<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="f1a2b3c4-0182-0001-general-event-federation" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="org_general_events"/>
            <not><columnExists tableName="org_general_events" columnName="federation_hidden"/></not>
        </preConditions>
        <addColumn tableName="org_general_events">
            <column name="federation_hidden" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="federation_hidden_at" type="TIMESTAMP"/>
            <column name="federation_hidden_by_user_id" type="BIGINT"/>
            <column name="federation_hidden_reason" type="VARCHAR(1000)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
