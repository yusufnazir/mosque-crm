<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- role_templates: master source for tenant role provisioning -->
    <changeSet id="3f8a1b2c-9d0e-4f56-a7b8-c9d0e1f2a3b4" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="role_templates"/></not>
        </preConditions>
        <createTable tableName="role_templates">
            <column name="id" type="BIGINT" autoIncrement="false">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
        </createTable>
    </changeSet>

    <!-- role_template_permissions: effective permissions granted by each template -->
    <changeSet id="4a9b2c3d-0e1f-4g67-b8c9-d0e1f2a3b4c5" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="role_template_permissions"/></not>
        </preConditions>
        <createTable tableName="role_template_permissions">
            <column name="template_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="permission_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="role_template_permissions"
                       columnNames="template_id, permission_id"
                       constraintName="pk_role_template_permissions"/>
        <addForeignKeyConstraint
            baseTableName="role_template_permissions" baseColumnNames="template_id"
            referencedTableName="role_templates" referencedColumnNames="id"
            constraintName="fk_rtp_template" onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableName="role_template_permissions" baseColumnNames="permission_id"
            referencedTableName="permissions" referencedColumnNames="id"
            constraintName="fk_rtp_permission" onDelete="CASCADE"/>
    </changeSet>

    <!-- role_template_assignable_permissions: the privilege pool for each template -->
    <changeSet id="5b0c3d4e-1f2a-4h78-c9d0-e1f2a3b4c5d6" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="role_template_assignable_permissions"/></not>
        </preConditions>
        <createTable tableName="role_template_assignable_permissions">
            <column name="template_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="permission_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="role_template_assignable_permissions"
                       columnNames="template_id, permission_id"
                       constraintName="pk_role_template_assignable_permissions"/>
        <addForeignKeyConstraint
            baseTableName="role_template_assignable_permissions" baseColumnNames="template_id"
            referencedTableName="role_templates" referencedColumnNames="id"
            constraintName="fk_rtap_template" onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableName="role_template_assignable_permissions" baseColumnNames="permission_id"
            referencedTableName="permissions" referencedColumnNames="id"
            constraintName="fk_rtap_permission" onDelete="CASCADE"/>
    </changeSet>

    <!-- Seed the sequences_ table entry for the role_templates TABLE generator -->
    <changeSet id="6c1d4e5f-2a3b-4i89-d0e1-f2a3b4c5d6e7" author="mosque-crm">
        <sql>
            INSERT IGNORE INTO sequences_ (PK_NAME, PK_VALUE) VALUES ('role_templates_seq', 1000);
        </sql>
    </changeSet>

</databaseChangeLog>
