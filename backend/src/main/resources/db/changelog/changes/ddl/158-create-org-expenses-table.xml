<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000015-0158-0000-0000-000000000001" author="mosque-crm">
        <createTable tableName="org_expenses">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="organization_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="expense_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="currency_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT"/>
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deletion_reason" type="VARCHAR(1000)"/>
            <column name="deleted_at" type="DATETIME"/>
            <column name="deleted_by" type="BIGINT"/>
            <column name="created_by" type="BIGINT"/>
            <column name="created_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="BIGINT"/>
            <column name="updated_at" type="DATETIME"/>
        </createTable>

        <createIndex tableName="org_expenses" indexName="idx_expenses_org_id">
            <column name="organization_id"/>
        </createIndex>
        <createIndex tableName="org_expenses" indexName="idx_expenses_date">
            <column name="expense_date"/>
        </createIndex>
        <createIndex tableName="org_expenses" indexName="idx_expenses_deleted">
            <column name="is_deleted"/>
        </createIndex>
    </changeSet>

    <changeSet id="b1000015-0158-0000-0000-000000000002" author="mosque-crm">
        <createTable tableName="org_expense_tag_mappings">
            <column name="expense_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="tag_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="org_expense_tag_mappings" columnNames="expense_id, tag_id"
                       constraintName="pk_expense_tag_mappings"/>
    </changeSet>

</databaseChangeLog>
