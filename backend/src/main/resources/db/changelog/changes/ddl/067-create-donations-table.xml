<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000005-0067-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="donations"/></not>
        </preConditions>
        <comment>Create donations table</comment>
        <createTable tableName="donations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="person_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="donation_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="donation_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="receipt_number" type="VARCHAR(50)"/>
            <column name="notes" type="VARCHAR(1000)"/>
            <column name="anonymous" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="organization_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
