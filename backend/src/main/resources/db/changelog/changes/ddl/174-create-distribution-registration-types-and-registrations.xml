<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000007-0174-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="org_events" columnName="parcel_kg_per_unit"/></not>
        </preConditions>
        <comment>Add kg per parcel on distribution events (default 1 kg = 1 parcel)</comment>
        <addColumn tableName="org_events">
            <column name="parcel_kg_per_unit" type="DECIMAL(10,2)" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="b1000007-0174-0000-0000-000000000002-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="org_distribution_registration_types"/></not>
        </preConditions>
        <comment>Configurable registration types per distribution event</comment>
        <createTable tableName="org_distribution_registration_types">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="fulfillment_mode" type="VARCHAR(20)" defaultValue="QUEUE">
                <constraints nullable="false"/>
            </column>
            <column name="default_planned_parcels" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="soft_limit" type="INT"/>
            <column name="assign_distribution_number" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="organization_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="b1000007-0174-0000-0000-000000000003-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="org_distribution_registrations"/></not>
        </preConditions>
        <comment>Unified parcel recipient registrations</comment>
        <createTable tableName="org_distribution_registrations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="registration_type_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="person_id" type="BIGINT"/>
            <column name="display_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="is_member" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="distribution_number" type="VARCHAR(20)"/>
            <column name="planned_parcel_count" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="distributed_parcel_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="id_number" type="VARCHAR(50)"/>
            <column name="phone_number" type="VARCHAR(100)"/>
            <column name="ad_hoc" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="REGISTERED">
                <constraints nullable="false"/>
            </column>
            <column name="registered_at" type="TIMESTAMP"/>
            <column name="organization_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
