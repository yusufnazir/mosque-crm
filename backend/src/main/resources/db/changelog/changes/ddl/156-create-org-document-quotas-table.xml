<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000015-0156-0000-0000-000000000001" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="org_document_quotas"/></not>
        </preConditions>
        <comment>Create org_document_quotas table — per-organisation storage and bandwidth tracking</comment>
        <createTable tableName="org_document_quotas">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="organization_id" type="BIGINT">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_doc_quotas_org"/>
            </column>
            <column name="storage_used_bytes" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="storage_limit_bytes" type="BIGINT"/>
            <column name="bandwidth_used_bytes" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="bandwidth_limit_bytes" type="BIGINT"/>
            <column name="bandwidth_reset_date" type="DATE"/>
            <column name="addon_storage_bytes" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="addon_bandwidth_bytes" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
