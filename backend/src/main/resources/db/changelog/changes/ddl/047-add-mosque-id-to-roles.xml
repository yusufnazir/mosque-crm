<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="047-add-mosque-id-to-roles" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="roles"/>
                <not>
                    <columnExists tableName="roles" columnName="mosque_id"/>
                </not>
            </and>
        </preConditions>

        <addColumn tableName="roles">
            <column name="mosque_id" type="BIGINT"/>
        </addColumn>

        <createIndex indexName="idx_roles_mosque" tableName="roles">
            <column name="mosque_id"/>
        </createIndex>

        <addForeignKeyConstraint baseTableName="roles"
                                 baseColumnNames="mosque_id"
                                 constraintName="fk_roles_mosque"
                                 referencedTableName="mosques"
                                 referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
