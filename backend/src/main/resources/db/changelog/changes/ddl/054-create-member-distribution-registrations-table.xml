<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="eid-dist-ddl-0004-create-member-distribution-registrations" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="member_distribution_registrations"/></not>
        </preConditions>
        <createTable tableName="member_distribution_registrations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="distribution_event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="person_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="REGISTERED">
                <constraints nullable="false"/>
            </column>
            <column name="registered_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
            <column name="mosque_id" type="BIGINT"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
