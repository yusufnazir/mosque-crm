<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000007-0084-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="parcel_distributions"/></not>
        </preConditions>
        <comment>Create parcel_distributions table</comment>
        <createTable tableName="parcel_distributions">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="distribution_event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="recipient_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="recipient_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="parcel_category_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="parcel_count" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="distributed_by" type="VARCHAR(255)"/>
            <column name="distributed_at" type="TIMESTAMP"/>
            <column name="organization_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
