<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Fix: The original uk_user_person constraint is a composite (user_id, person_id),
        which allows the same person_id with different user_ids. This breaks the @OneToOne
        mapping from Person to UserMemberLink. We need individual unique constraints.
    -->

    <!-- Step 1: Remove duplicate person_id entries (keep lowest id per person_id) -->
    <changeSet id="038-fix-uml-dedup-person" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="user_member_link"/>
        </preConditions>
        <sql>
            DELETE uml FROM user_member_link uml
            INNER JOIN (
                SELECT person_id, MIN(id) AS keep_id
                FROM user_member_link
                GROUP BY person_id
                HAVING COUNT(*) > 1
            ) dups ON uml.person_id = dups.person_id AND uml.id != dups.keep_id;
        </sql>
        <comment>Remove duplicate user_member_link rows per person_id, keeping the oldest entry</comment>
    </changeSet>

    <!-- Step 2: Remove duplicate user_id entries (keep lowest id per user_id) -->
    <changeSet id="038-fix-uml-dedup-user" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="user_member_link"/>
        </preConditions>
        <sql>
            DELETE uml FROM user_member_link uml
            INNER JOIN (
                SELECT user_id, MIN(id) AS keep_id
                FROM user_member_link
                GROUP BY user_id
                HAVING COUNT(*) > 1
            ) dups ON uml.user_id = dups.user_id AND uml.id != dups.keep_id;
        </sql>
        <comment>Remove duplicate user_member_link rows per user_id, keeping the oldest entry</comment>
    </changeSet>

    <!-- Step 3: Add individual unique constraint on person_id -->
    <changeSet id="038-fix-uml-uk-person" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><indexExists indexName="uk_user_member_link_person_id" tableName="user_member_link"/></not>
        </preConditions>
        <addUniqueConstraint tableName="user_member_link" columnNames="person_id"
                             constraintName="uk_user_member_link_person_id"/>
        <comment>One person can only be linked to one user account</comment>
    </changeSet>

    <!-- Step 4: Add individual unique constraint on user_id -->
    <changeSet id="038-fix-uml-uk-user" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><indexExists indexName="uk_user_member_link_user_id" tableName="user_member_link"/></not>
        </preConditions>
        <addUniqueConstraint tableName="user_member_link" columnNames="user_id"
                             constraintName="uk_user_member_link_user_id"/>
        <comment>One user account can only be linked to one person</comment>
    </changeSet>

</databaseChangeLog>
