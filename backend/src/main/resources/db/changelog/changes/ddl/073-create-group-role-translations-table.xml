<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000006-0073-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="group_role_translations"/></not>
        </preConditions>
        <comment>Create group_role_translations table</comment>
        <createTable tableName="group_role_translations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="group_role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="locale" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="group_role_translations"
                             columnNames="group_role_id, locale"
                             constraintName="uk_group_role_trans_role_locale"/>
    </changeSet>

</databaseChangeLog>
