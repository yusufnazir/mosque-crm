<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000007-0176-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="org_event_sacrifice_animal_shares" columnName="entitlement_received"/></not>
        </preConditions>
        <comment>Track whether a shareholder received their meat entitlement</comment>
        <addColumn tableName="org_event_sacrifice_animal_shares">
            <column name="entitlement_received" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="entitlement_received_at" type="TIMESTAMP"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
