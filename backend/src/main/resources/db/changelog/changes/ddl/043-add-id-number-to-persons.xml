<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="043-add-id-number-to-persons" author="system">
        <comment>Add id_number column to persons table for external ID / national ID / CBB ID</comment>
        <addColumn tableName="persons">
            <column name="id_number" type="VARCHAR(50)" />
        </addColumn>
    </changeSet>

</databaseChangeLog>
