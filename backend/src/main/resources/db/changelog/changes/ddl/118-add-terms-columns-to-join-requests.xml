<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="118-add-terms-version-id-to-join-requests" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="join_requests"/>
            <not>
                <columnExists tableName="join_requests" columnName="terms_version_id"/>
            </not>
        </preConditions>
        <addColumn tableName="join_requests">
            <column name="terms_version_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <changeSet id="118-add-terms-version-number-to-join-requests" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="join_requests"/>
            <not>
                <columnExists tableName="join_requests" columnName="terms_version_number"/>
            </not>
        </preConditions>
        <addColumn tableName="join_requests">
            <column name="terms_version_number" type="INT"/>
        </addColumn>
    </changeSet>

    <changeSet id="118-add-terms-title-to-join-requests" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="join_requests"/>
            <not>
                <columnExists tableName="join_requests" columnName="terms_title"/>
            </not>
        </preConditions>
        <addColumn tableName="join_requests">
            <column name="terms_title" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="118-add-terms-accepted-at-to-join-requests" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="join_requests"/>
            <not>
                <columnExists tableName="join_requests" columnName="terms_accepted_at"/>
            </not>
        </preConditions>
        <addColumn tableName="join_requests">
            <column name="terms_accepted_at" type="DATETIME"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>