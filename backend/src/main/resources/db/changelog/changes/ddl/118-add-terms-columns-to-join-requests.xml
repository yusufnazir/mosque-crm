<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="118-add-terms-columns-to-join-requests" author="mosque-crm">
        <addColumn tableName="join_requests">
            <column name="terms_version_id" type="BIGINT"/>
            <column name="terms_version_number" type="INT"/>
            <column name="terms_title" type="VARCHAR(255)"/>
            <column name="terms_accepted_at" type="DATETIME"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>