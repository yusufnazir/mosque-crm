<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Role Assignable Roles (role governance / delegation table).
        Defines which roles a given role is allowed to assign to users.
        This is the "role pool" counterpart of role_assignable_permissions (the "permission pool").
        See MULTI-TENANT-SECURITY.md §3.9 (RoleAssignableRole).
    -->
    <changeSet id="050-create-role-assignable-roles" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="role_assignable_roles"/></not>
        </preConditions>
        <createTable tableName="role_assignable_roles">
            <column name="role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="assignable_role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="role_assignable_roles"
                       columnNames="role_id, assignable_role_id"
                       constraintName="pk_role_assignable_roles"/>
    </changeSet>

    <!--
        Role Template Assignable Roles (template-level role delegation).
        When provisioning tenant roles, these template→template mappings are
        resolved to tenant-role→tenant-role entries in role_assignable_roles.
    -->
    <changeSet id="050-create-role-template-assignable-roles" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="role_template_assignable_roles"/></not>
        </preConditions>
        <createTable tableName="role_template_assignable_roles">
            <column name="template_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="assignable_template_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="role_template_assignable_roles"
                       columnNames="template_id, assignable_template_id"
                       constraintName="pk_role_template_assignable_roles"/>
    </changeSet>

</databaseChangeLog>
