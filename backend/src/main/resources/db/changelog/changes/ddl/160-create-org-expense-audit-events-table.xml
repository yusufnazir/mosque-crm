<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000015-0160-0000-0000-000000000001" author="mosque-crm">
        <createTable tableName="org_expense_audit_events">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="expense_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="organization_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT"/>
            <column name="detail" type="VARCHAR(1000)"/>
            <column name="occurred_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="org_expense_audit_events" indexName="idx_exp_audit_expense_id">
            <column name="expense_id"/>
        </createIndex>
        <createIndex tableName="org_expense_audit_events" indexName="idx_exp_audit_org_id">
            <column name="organization_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
