<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000003-0161-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="persons" columnName="family_number"/></not>
        </preConditions>
        <comment>Add family number and civil state columns to persons</comment>
        <addColumn tableName="persons">
            <column name="family_number" type="VARCHAR(50)"/>
            <column name="civil_state" type="VARCHAR(100)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
