<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="f1a2b3c4-0190-0001-business-listing-suspension" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="business_listings"/>
            <not><columnExists tableName="business_listings" columnName="suspension_reason"/></not>
        </preConditions>
        <addColumn tableName="business_listings">
            <column name="suspension_reason" type="VARCHAR(1000)"/>
            <column name="suspended_at" type="TIMESTAMP"/>
            <column name="suspended_by_user_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
