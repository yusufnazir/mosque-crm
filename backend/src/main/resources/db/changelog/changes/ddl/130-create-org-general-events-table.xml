<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000007-0130-0000-0000-000000000001-2" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="org_general_events"/></not>
        </preConditions>
        <comment>Create org_general_events table for general event management</comment>
        <createTable tableName="org_general_events">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="general_event_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="custom_type_label" type="VARCHAR(100)"/>
            <column name="location" type="VARCHAR(500)"/>
            <column name="is_online" type="TINYINT(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="meeting_url" type="VARCHAR(500)"/>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="VARCHAR(20)"/>
            <column name="end_time" type="VARCHAR(20)"/>
            <column name="requires_registration" type="TINYINT(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="registration_open_date" type="DATE"/>
            <column name="registration_close_date" type="DATE"/>
            <column name="member_capacity" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="non_member_capacity" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="accept_non_members" type="TINYINT(1)" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="waitlist_enabled" type="TINYINT(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="ticketing_type" type="VARCHAR(20)" defaultValue="NONE">
                <constraints nullable="false"/>
            </column>
            <column name="ticket_price" type="DECIMAL(10,2)"/>
            <column name="currency" type="VARCHAR(10)" defaultValue="EUR">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="visibility" type="VARCHAR(30)" defaultValue="MEMBERS_ONLY">
                <constraints nullable="false"/>
            </column>
            <column name="featured" type="TINYINT(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="requires_check_in" type="TINYINT(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="check_in_code" type="VARCHAR(20)"/>
            <column name="organization_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
