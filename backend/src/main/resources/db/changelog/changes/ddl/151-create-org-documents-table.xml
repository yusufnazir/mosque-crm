<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000015-0151-0000-0000-000000000001" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="org_documents"/></not>
        </preConditions>
        <comment>Create org_documents table for document management module</comment>
        <createTable tableName="org_documents">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="organization_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="folder_id" type="BIGINT"/>
            <column name="title" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(2000)"/>
            <column name="document_type" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="mime_type" type="VARCHAR(200)"/>
            <column name="storage_key" type="VARCHAR(1000)"/>
            <column name="content_html" type="LONGTEXT"/>
            <column name="file_size" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="original_filename" type="VARCHAR(500)"/>
            <column name="status" type="VARCHAR(30)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="visibility" type="VARCHAR(30)" defaultValue="PRIVATE">
                <constraints nullable="false"/>
            </column>
            <column name="owner_user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="version_count" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMP"/>
            <column name="expiry_notification_sent" type="TINYINT(1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="deleted_by" type="BIGINT"/>
            <column name="created_by" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
