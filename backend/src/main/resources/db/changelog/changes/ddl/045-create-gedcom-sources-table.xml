<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000004-0045-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="gedcom_sources"/></not>
        </preConditions>
        <comment>Create gedcom_sources table (GEDCOM SOUR records)</comment>
        <createTable tableName="gedcom_sources">
            <column name="id" type="VARCHAR(20)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="author" type="VARCHAR(255)"/>
            <column name="publication" type="VARCHAR(255)"/>
            <column name="repository" type="VARCHAR(255)"/>
            <column name="call_number" type="VARCHAR(100)"/>
            <column name="notes" type="TEXT"/>
            <column name="organization_id" type="BIGINT"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
