<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="f1a2b3c4-0191-0001-business-logo-image-key" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="businesses"/>
            <not><columnExists tableName="businesses" columnName="logo_image_key"/></not>
        </preConditions>
        <addColumn tableName="businesses">
            <column name="logo_image_key" type="VARCHAR(500)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
