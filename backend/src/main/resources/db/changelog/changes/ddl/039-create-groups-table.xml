<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="039-create-groups-table" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="groups"/></not>
        </preConditions>

        <createTable tableName="groups">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(2000)"/>
            <column name="start_date" type="DATE"/>
            <column name="end_date" type="DATE"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_by" type="BIGINT"/>
            <column name="mosque_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex indexName="idx_groups_mosque" tableName="groups">
            <column name="mosque_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="039-create-group-members-table" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="group_members"/></not>
        </preConditions>

        <createTable tableName="group_members">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="group_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="person_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="DATE"/>
            <column name="end_date" type="DATE"/>
            <column name="role_in_group" type="VARCHAR(100)"/>
            <column name="created_by" type="BIGINT"/>
            <column name="mosque_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex indexName="idx_groupmembers_group" tableName="group_members">
            <column name="group_id"/>
        </createIndex>
        <createIndex indexName="idx_groupmembers_person" tableName="group_members">
            <column name="person_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
