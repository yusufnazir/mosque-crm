<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Group Roles: predefined roles within a group (e.g., Chairman, Secretary) -->
    <changeSet id="041-create-group-roles-table" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="group_roles"/></not>
        </preConditions>
        <createTable tableName="group_roles">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="group_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT" defaultValueNumeric="0"/>
            <column name="max_members" type="INT">
                <!-- NULL means unlimited; 1 means only one person can hold the role -->
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="mosque_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex indexName="idx_group_roles_group" tableName="group_roles">
            <column name="group_id"/>
        </createIndex>
        <createIndex indexName="idx_group_roles_mosque" tableName="group_roles">
            <column name="mosque_id"/>
        </createIndex>
    </changeSet>

    <!-- Group Role Translations: i18n names for each role -->
    <changeSet id="041-create-group-role-translations-table" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="group_role_translations"/></not>
        </preConditions>
        <createTable tableName="group_role_translations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="group_role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="locale" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="group_role_translations"
                             columnNames="group_role_id, locale"
                             constraintName="uq_group_role_trans_locale"/>

        <createIndex tableName="group_role_translations" indexName="idx_group_role_trans_role">
            <column name="group_role_id"/>
        </createIndex>
    </changeSet>

    <!-- Add group_role_id FK column to group_members -->
    <changeSet id="041-add-group-role-id-to-group-members" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="group_members" columnName="group_role_id"/></not>
        </preConditions>
        <addColumn tableName="group_members">
            <column name="group_role_id" type="BIGINT"/>
        </addColumn>
        <createIndex tableName="group_members" indexName="idx_groupmembers_role">
            <column name="group_role_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
