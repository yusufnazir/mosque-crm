<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000005-0069-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="exchange_rates"/></not>
        </preConditions>
        <comment>Create exchange_rates table</comment>
        <createTable tableName="exchange_rates">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="organization_id" type="BIGINT"/>
            <column name="from_currency_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="to_currency_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="rate" type="DECIMAL(18,8)">
                <constraints nullable="false"/>
            </column>
            <column name="effective_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
