<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000005-0110-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="member_payments" columnName="payment_group_id"/></not>
        </preConditions>
        <comment>Add payment_group_id column to member_payments for grouping multi-period payments</comment>
        <addColumn tableName="member_payments">
            <column name="payment_group_id" type="VARCHAR(36)"/>
        </addColumn>
        <createIndex indexName="idx_mempay_group_id" tableName="member_payments">
            <column name="payment_group_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
