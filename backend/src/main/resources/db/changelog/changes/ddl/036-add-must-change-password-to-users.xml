<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="f1a2b3c4-0036-4aaa-bbbb-must-change-pwd" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="users" columnName="must_change_password"/>
            </not>
        </preConditions>
        <addColumn tableName="users">
            <column name="must_change_password" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
