    <!-- ======================================================================
         CHANGESET 1: DROP ALL FOREIGN KEYS
         Uses a MariaDB stored procedure to iterate INFORMATION_SCHEMA and
         drop every FK in the current schema. runAlways ensures idempotent
         re-creation each startup.
         ====================================================================== -->
    <changeSet id="b1000099-9990-0000-0000-000000000001-1" author="mosque-crm" runAlways="false">
        <comment>Drop all foreign keys so they can be recreated cleanly</comment>
        <sql>DROP PROCEDURE IF EXISTS drop_all_foreign_keys</sql>
        <createProcedure>
            CREATE PROCEDURE drop_all_foreign_keys()
            BEGIN
                DECLARE done INT DEFAULT 0;
                DECLARE fk_name VARCHAR(255);
                DECLARE tbl_name VARCHAR(255);
                DECLARE cur CURSOR FOR
                    SELECT CONSTRAINT_NAME, TABLE_NAME
                    FROM INFORMATION_SCHEMA.TABLE_CONSTRAINTS
                    WHERE CONSTRAINT_TYPE = 'FOREIGN KEY'
                      AND TABLE_SCHEMA = DATABASE();
                DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;
                OPEN cur;
                read_loop: LOOP
                    FETCH cur INTO fk_name, tbl_name;
                    IF done THEN LEAVE read_loop; END IF;
                    SET @sql = CONCAT('ALTER TABLE `', tbl_name, '` DROP FOREIGN KEY `', fk_name, '`');
                    PREPARE stmt FROM @sql;
                    EXECUTE stmt;
                    DEALLOCATE PREPARE stmt;
                END LOOP;
                CLOSE cur;
            END
        </createProcedure>
        <sql>CALL drop_all_foreign_keys()</sql>
        <sql>DROP PROCEDURE IF EXISTS drop_all_foreign_keys</sql>
    </changeSet>

    <!-- ======================================================================
         CHANGESET 2: DROP ALL idx_fk_* INDEXES
         Removes generated FK indexes so they can be recreated cleanly.
         ====================================================================== -->
    <changeSet id="b1000099-9990-0000-0000-000000000002-1" author="mosque-crm" runAlways="false">
        <comment>Drop all idx_fk_* indexes so they can be recreated cleanly</comment>
        <sql>DROP PROCEDURE IF EXISTS drop_all_fk_indexes</sql>
        <createProcedure>
            CREATE PROCEDURE drop_all_fk_indexes()
            BEGIN
                DECLARE done INT DEFAULT 0;
                DECLARE idx_name VARCHAR(255);
                DECLARE tbl_name VARCHAR(255);
                DECLARE cur CURSOR FOR
                    SELECT DISTINCT s.INDEX_NAME, s.TABLE_NAME
                    FROM INFORMATION_SCHEMA.STATISTICS s
                    WHERE s.TABLE_SCHEMA = DATABASE()
                      AND s.INDEX_NAME LIKE 'idx_fk_%';
                DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;
                OPEN cur;
                read_loop: LOOP
                    FETCH cur INTO idx_name, tbl_name;
                    IF done THEN LEAVE read_loop; END IF;
                    SET @sql = CONCAT('DROP INDEX `', idx_name, '` ON `', tbl_name, '`');
                    PREPARE stmt FROM @sql;
                    EXECUTE stmt;
                    DEALLOCATE PREPARE stmt;
                END LOOP;
                CLOSE cur;
            END
        </createProcedure>
        <sql>CALL drop_all_fk_indexes()</sql>
        <sql>DROP PROCEDURE IF EXISTS drop_all_fk_indexes</sql>
    </changeSet>

