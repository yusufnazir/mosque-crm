    <changeSet id="b1000099-9990-0000-0000-000000000007-1" author="mosque-crm" runAlways="false">
        <comment>Create foreign keys for subscription billing tables</comment>

        <!-- subscription_invoices → organizations, organization_subscriptions -->
        <addForeignKeyConstraint constraintName="fk_subinvoice_org"
            baseTableName="subscription_invoices" baseColumnNames="organization_id"
            referencedTableName="organizations" referencedColumnNames="id"/>
        <addForeignKeyConstraint constraintName="fk_subinvoice_sub"
            baseTableName="subscription_invoices" baseColumnNames="subscription_id"
            referencedTableName="organization_subscriptions" referencedColumnNames="id"/>

        <!-- subscription_payments → organizations, subscription_invoices -->
        <addForeignKeyConstraint constraintName="fk_subpayment_org"
            baseTableName="subscription_payments" baseColumnNames="organization_id"
            referencedTableName="organizations" referencedColumnNames="id"/>
        <addForeignKeyConstraint constraintName="fk_subpayment_invoice"
            baseTableName="subscription_payments" baseColumnNames="invoice_id"
            referencedTableName="subscription_invoices" referencedColumnNames="id"/>
