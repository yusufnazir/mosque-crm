<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="eid-dist-ddl-0006-add-event-type" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="distribution_events"/>
            <not><columnExists tableName="distribution_events" columnName="event_type"/></not>
        </preConditions>
        <addColumn tableName="distribution_events">
            <column name="event_type" type="VARCHAR(50)" defaultValue="EID_UL_ADHA_DISTRIBUTION">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
