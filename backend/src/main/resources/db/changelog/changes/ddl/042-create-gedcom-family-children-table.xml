<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000004-0042-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="gedcom_family_children"/></not>
        </preConditions>
        <comment>Create gedcom_family_children table (children belong to families)</comment>
        <createTable tableName="gedcom_family_children">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="family_id" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="child_id" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="relationship_type" type="VARCHAR(20)" defaultValue="BIOLOGICAL">
                <constraints nullable="false"/>
            </column>
            <column name="birth_order" type="INT"/>
            <column name="organization_id" type="BIGINT"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
