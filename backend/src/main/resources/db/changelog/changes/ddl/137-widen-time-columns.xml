<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="b1000007-0137-0000-0000-000000000001-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="org_general_events"/>
        </preConditions>
        <comment>Widen start_time and end_time columns from VARCHAR(10) to VARCHAR(20) to accommodate full LocalTime.toString() output (e.g. HH:mm:ss.SSSSSSSSS)</comment>
        <modifyDataType tableName="org_general_events" columnName="start_time" newDataType="VARCHAR(20)"/>
        <modifyDataType tableName="org_general_events" columnName="end_time" newDataType="VARCHAR(20)"/>
    </changeSet>

    <changeSet id="b1000007-0137-0000-0000-000000000002-1" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="org_general_event_sessions"/>
        </preConditions>
        <comment>Widen start_time and end_time columns in org_general_event_sessions from VARCHAR(10) to VARCHAR(20)</comment>
        <modifyDataType tableName="org_general_event_sessions" columnName="start_time" newDataType="VARCHAR(20)"/>
        <modifyDataType tableName="org_general_event_sessions" columnName="end_time" newDataType="VARCHAR(20)"/>
    </changeSet>

</databaseChangeLog>
