<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="f1a2b3c4-0183-0001-federation-invite-code" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="organizations"/>
            <not><columnExists tableName="organizations" columnName="federation_invite_code"/></not>
        </preConditions>
        <addColumn tableName="organizations">
            <column name="federation_invite_code" type="VARCHAR(20)"/>
        </addColumn>
        <createIndex indexName="idx_organizations_federation_invite_code" tableName="organizations" unique="true">
            <column name="federation_invite_code"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
