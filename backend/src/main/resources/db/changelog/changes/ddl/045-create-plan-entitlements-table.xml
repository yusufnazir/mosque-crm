<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Feature entitlement matrix per plan -->
    <changeSet id="045-create-plan-entitlements-table" author="mosque-crm">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="plan_entitlements"/></not>
        </preConditions>

        <createTable tableName="plan_entitlements">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="plan_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="feature_key" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="limit_value" type="INT"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>

        <addUniqueConstraint tableName="plan_entitlements"
                             columnNames="plan_id, feature_key"
                             constraintName="uq_plan_entitlements_plan_feature"/>

        <createIndex tableName="plan_entitlements" indexName="idx_plan_entitlements_plan_id">
            <column name="plan_id"/>
        </createIndex>
        <createIndex tableName="plan_entitlements" indexName="idx_plan_entitlements_feature">
            <column name="feature_key"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
