<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="094-create-saved-member-filters-table" author="mosque-crm">
        <createTable tableName="saved_member_filters">
            <column name="id" type="BIGINT" autoIncrement="false">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="organization_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_by_user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="filter_json" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="is_default" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="true"/>
            </column>
            <column name="updated_at" type="DATETIME">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex tableName="saved_member_filters" indexName="idx_saved_filters_org_user">
            <column name="organization_id"/>
            <column name="created_by_user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
