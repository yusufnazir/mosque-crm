<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="057-add-capacity-to-distribution-events" author="system">
        <comment>Add member and non-member capacity limits to distribution events</comment>

        <addColumn tableName="distribution_events">
            <column name="member_capacity" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="non_member_capacity" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
