# Production Environment Variables Template
# Copy this file to .env and set actual values
# NEVER commit .env file to source control!

# ====================
# CRITICAL SECURITY
# ====================

# JWT Secret - Generate with: openssl rand -base64 32
# MUST be different for dev/staging/production
JWT_SECRET=REPLACE_WITH_RANDOM_256BIT_STRING

# JWT Token Expiration (milliseconds)
# 86400000 = 24 hours
# 604800000 = 7 days
JWT_EXPIRATION=86400000

# ====================
# DATABASE
# ====================

DB_HOST=localhost
DB_PORT=3307
DB_NAME=mcrm
DB_USERNAME=mcrm
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ====================
# CORS
# ====================

# Production: Use your actual frontend domain with HTTPS
# Example: https://app.mosque.com
# Multiple origins: comma-separated
CORS_ALLOWED_ORIGINS=https://app.mosque.com

# ====================
# SERVER
# ====================

SERVER_PORT=8080

# Email Configuration (for password reset)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@mosque.com

# ====================
# SSL/TLS (HTTPS)
# ====================

# Enable HTTPS in production
# Generate certificate with: certbot or mkcert
SERVER_SSL_ENABLED=true
SERVER_SSL_KEY_STORE=classpath:keystore.p12
SERVER_SSL_KEY_STORE_PASSWORD=REPLACE_WITH_KEYSTORE_PASSWORD
SERVER_SSL_KEY_STORE_TYPE=PKCS12
SERVER_SSL_KEY_ALIAS=mosque-crm
