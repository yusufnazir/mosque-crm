# Backend URL (server-side only, used by the BFF proxy)
# Default: http://localhost:8080/api
# For Docker: BACKEND_URL=http://backend:8080/api
#
# This is a server-side variable — never exposed to the browser.
# The browser only communicates with Next.js on the same origin.
# BACKEND_URL=http://localhost:8080/api

# Base domain for wildcard-subdomain multi-tenancy (optional).
#
# When set, the application uses subdomain routing:
#   auth.<domain>          →  login entry point
#   <org-handle>.<domain>  →  tenant application
#
# For local development, lvh.me is recommended — all *.lvh.me subdomains
# resolve to 127.0.0.1 automatically, so no /etc/hosts edits are needed.
#   Visit:  http://auth.lvh.me:3000   to log in
#   After login you are redirected to http://<handle>.lvh.me:3000
#
# Leave commented out to use single-origin mode (classic /login behaviour).
# NEXT_PUBLIC_BASE_DOMAIN=lvh.me

# Subdomain reserved for the super admin (default: admin → admin.<domain>).
# Must match app.superadmin-subdomain in the backend application.properties.
# NEXT_PUBLIC_SUPERADMIN_SUBDOMAIN=admin
